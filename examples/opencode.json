{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "fusion": {
      "type": "local",
      "command": ["uvx", "openrouter-fusion-agent", "--mcp"],
      "enabled": true,
      "environment": {
        "OPENROUTER_API_KEY": "{file:~/.config/openrouter/api_key}"
      },
      "timeout": 300000
    }
  }
}
